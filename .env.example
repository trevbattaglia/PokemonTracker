# Copy to .env and fill in. .env is gitignored -- never commit the real URL.
# Anyone holding this URL can post to your channel.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy

# Timezone used to anchor date-only release dates and to render "morning of".
# Defaults to America/Los_Angeles (Pokemon Center announces drop times in PT).
PKMN_TZ=America/Los_Angeles
